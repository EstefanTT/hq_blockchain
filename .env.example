# Environment
MACHINE_TYPE=laptop_msi          # laptop_msi | production_server
NODE_ENV=development             # development | production

# API
PORT=3001
HOST=0.0.0.0
API_TOKEN=your_api_token_here

# Messaging
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Chain RPCs (add as needed)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
SOL_RPC_URL=https://api.mainnet-beta.solana.com

# CEX API keys (add as needed)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# External APIs
COINGECKO_API_KEY=
COINMARKETCAP_API_KEY=
ETHERSCAN_API_KEY=

# Steem-like accounts (active key is needed for placing/cancelling orders)
STEEM_ACCOUNT=your_steem_username
STEEM_ACTIVE_KEY=your_steem_active_private_key
# HIVE_ACCOUNT=your_hive_username
# HIVE_ACTIVE_KEY=your_hive_active_private_key
